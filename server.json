{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Ronit-019/finance-intelligence-mcp",
  "description": "A production-ready Model Context Protocol (MCP) server for secure personal finance management, expense tracking, budgeting, analytics, and financial health insights using PostgreSQL.",
  "repository": {
    "url": "https://github.com/Ronit-019/Finance-Intelligence-MCP",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "finance-intelligence-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DATABASE_URL",
          "description": "PostgreSQL connection string.",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}